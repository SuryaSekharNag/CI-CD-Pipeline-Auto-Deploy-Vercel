pipeline {
    agent any

    environment {
        VERCEL_TOKEN = credentials('vercel_token')
    }

    stages {
        stage('Install') {
            steps {
                echo 'Skiping Tests -  No Tests....'
            }
        }

        stage('Test') {
            steps {
                bat 'npm install'
            }
        }

        stage('Build') {
            steps {
                bat 'npm run build'
            }
        }

        stage('Deploy') {
            steps {
                bat 'npx vercel --prod --yes -- --token=%VERCEL_TOKEN%'
            }
        }
    }
}